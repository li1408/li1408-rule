<script is:inline>
  (() => {
    const storageKey = "li1408_startup_intro_seen";
    const intro = document.getElementById("li1408-startup-intro");
    const wipe = document.getElementById("li1408-startup-wipe");
    if (!intro || !wipe) return;

    const params = new URLSearchParams(window.location.search);
    const forceIntro = params.has("intro");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function hasSeenIntro() {
      try {
        return sessionStorage.getItem(storageKey) === "1";
      } catch {
        return false;
      }
    }

    function markSeen() {
      try {
        sessionStorage.setItem(storageKey, "1");
      } catch {
        // Session storage can be unavailable in some privacy modes.
      }
    }

    function skipIntro() {
      intro.remove();
      wipe.remove();
      document.body.classList.remove("li1408-intro-playing");
      document.body.classList.add("li1408-intro-complete");
    }

    if ((!forceIntro && hasSeenIntro()) || reduceMotion) {
      skipIntro();
      return;
    }

    const count = document.getElementById("li1408-count");
    const bar = document.getElementById("li1408-bar");
    const status = document.getElementById("li1408-status");
    const statusTitle = document.getElementById("li1408-status-title");
    const statusSteps = [
      [0, "collecting notes", "sorting fragments"],
      [26, "aligning thoughts", "mapping archive"],
      [52, "checking projects", "personal system"],
      [74, "restoring homepage", "almost ready"],
      [92, "opening li1408", "ready"],
    ];

    let renderedCount = -1;
    let renderedStatusIndex = -1;
    let frame = 0;

    function setProgress(value) {
      const next = Math.max(0, Math.min(100, Math.round(value)));
      bar.style.transform = `scaleX(${next / 100})`;

      if (next !== renderedCount) {
        count.textContent = String(next).padStart(3, "0") + "%";
        renderedCount = next;
      }

      let activeIndex = 0;
      for (let i = 0; i < statusSteps.length; i += 1) {
        if (next >= statusSteps[i][0]) activeIndex = i;
      }

      if (activeIndex !== renderedStatusIndex) {
        const active = statusSteps[activeIndex];
        status.textContent = active[1];
        statusTitle.textContent = active[2];
        renderedStatusIndex = activeIndex;
      }
    }

    function runCounter(duration = 3150) {
      cancelAnimationFrame(frame);
      const start = performance.now();

      function tick(now) {
        const elapsed = now - start;
        const raw = Math.min(1, elapsed / duration);
        const eased = raw * raw * (3 - 2 * raw);
        const jitter = raw > 0.12 && raw < 0.88 ? Math.sin(raw * 22) * 1.7 : 0;
        setProgress(eased * 100 + jitter);

        if (raw < 1) {
          frame = requestAnimationFrame(tick);
        } else {
          setProgress(100);
        }
      }

      frame = requestAnimationFrame(tick);
    }

    document.body.classList.remove("li1408-intro-complete");
    document.body.classList.add("li1408-intro-playing");
    setProgress(0);
    markSeen();
    runCounter();

    window.setTimeout(() => {
      intro.classList.add("is-leaving");
    }, 3300);

    window.setTimeout(() => {
      document.body.classList.add("li1408-intro-revealing");
    }, 3850);

    window.setTimeout(() => {
      cancelAnimationFrame(frame);
      intro.remove();
      wipe.remove();
      document.body.classList.remove("li1408-intro-playing");
    }, 4620);

    window.setTimeout(() => {
      document.body.classList.remove("li1408-intro-revealing");
      document.body.classList.add("li1408-intro-complete");
    }, 4960);
  })();
</script>
