<style is:global>
  #nprogress {
    pointer-events: none;
  }

  #nprogress .bar {
    position: fixed;
    z-index: 2147483647;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    color: inherit;
    background: currentColor;
    transform-origin: left center;
  }

  #nprogress .peg {
    position: absolute;
    right: 0;
    display: block;
    width: 72px;
    height: 100%;
    opacity: 0.55;
    box-shadow: 0 0 8px currentColor;
    transform: rotate(2deg) translateY(-1px);
  }

  html[data-navigation-pending] {
    cursor: progress;
  }

  html[data-navigation-pending] a[data-navigation-source] {
    opacity: 0.72;
  }

  ::view-transition-old(root) {
    animation: 180ms cubic-bezier(0.4, 0, 1, 1) both li1408PageForwardOut;
  }

  ::view-transition-new(root) {
    animation: 260ms cubic-bezier(0.16, 1, 0.3, 1) both li1408PageForwardIn;
  }

  html[data-astro-transition="back"]::view-transition-old(root) {
    animation-name: li1408PageBackOut;
  }

  html[data-astro-transition="back"]::view-transition-new(root) {
    animation-name: li1408PageBackIn;
  }

  @keyframes li1408PageForwardOut {
    to {
      opacity: 0.78;
      transform: translateX(-10px);
    }
  }

  @keyframes li1408PageForwardIn {
    from {
      opacity: 0.58;
      transform: translateX(18px);
    }
  }

  @keyframes li1408PageBackOut {
    to {
      opacity: 0.78;
      transform: translateX(10px);
    }
  }

  @keyframes li1408PageBackIn {
    from {
      opacity: 0.58;
      transform: translateX(-18px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 1ms !important;
      transform: none !important;
    }

    #nprogress .bar {
      transition: none !important;
    }
  }
</style>

<script>
  import NProgress from "nprogress";

  NProgress.configure({
    minimum: 0.12,
    easing: "ease",
    speed: 180,
    trickle: true,
    trickleSpeed: 180,
    showSpinner: false,
  });

  let activeLink;

  const clearNavigationState = () => {
    document.documentElement.removeAttribute("data-navigation-pending");
    document.documentElement.removeAttribute("aria-busy");
    activeLink?.removeAttribute("data-navigation-source");
    activeLink = undefined;
  };

  document.addEventListener("astro:before-preparation", (event) => {
    const source = event.sourceElement;
    activeLink = source instanceof Element ? source.closest("a") : undefined;
    activeLink?.setAttribute("data-navigation-source", "");

    document.documentElement.setAttribute("data-navigation-pending", "");
    document.documentElement.setAttribute("aria-busy", "true");
    NProgress.start();
  });

  document.addEventListener("astro:after-preparation", () => {
    NProgress.set(0.82);
  });

  document.addEventListener("astro:after-swap", () => {
    NProgress.set(0.96);
  });

  document.addEventListener("astro:page-load", () => {
    NProgress.done();
    clearNavigationState();
  });
</script>
