---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="项目 | li1408" sideBarActiveItemID="projects">
  <div class="mb-8">
    <div class="text-3xl w-full font-bold mb-3">项目</div>
    <p class="text-lg leading-8 opacity-80">
      这里放一些我真正部署过、折腾过、打磨过的网站。它们不一定都很复杂，但每一个都对应一段学习过程。
    </p>
  </div>

  <HorizontalCard
    title="see140 视觉交互网站"
    img="/project-see140.png"
    desc="一个用摄像头识别手势的 3D 画板。可以用手画线、双手缩放、切换重力模式，也有粒子清除和黑白启动动画。"
    url="/blog/see140-gesture-canvas/"
    target="_self"
    badge="个人创作"
    actionLabel="查看记录"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="GitHub 资源部署记录"
    img="/project-lsldsb.png"
    desc="我第一次正式在 GitHub 上找资源，参考零度解说的教程，把一个影视、直播、资源类项目部署到自己的电脑并上线到 Cloudflare。访问密码：140dsb。"
    url="https://lsldsb.dpdns.org"
    badge="Cloudflare"
    actionLabel="打开网站"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="NewsNow 信息聚合站"
    img="/project-newsnow.png"
    desc="GitHub 上的主流平台信息聚合项目。我曾经把它部署到 Cloudflare Pages，也尝试过绑定自己的域名。"
    url="https://newsnow-76c.pages.dev/"
    badge="Pages"
    actionLabel="打开网站"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="140035.xyz 手机卡推荐页"
    img="/project-140035.png"
    desc="第一次接触 Codex 时，用很简单的话让它帮我写出来的网站。页面参考苹果官网的大留白和圆润设计，用来展示大流量手机卡推荐。"
    url="https://140035.xyz/?from=li1408-blog"
    badge="Codex"
    actionLabel="打开网站"
  />
</BaseLayout>
